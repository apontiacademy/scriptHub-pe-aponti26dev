# ==============================================================================
# CONFIGURAÇÕES DO MOODLE — AUTOMAÇÃO DE FÓRUNS
# ==============================================================================
MOODLE_USERNAME=seu_usuario_aqui
MOODLE_PASSWORD=sua_senha_aqui

# URL da página de login do Moodle
MOODLE_LOGIN_URL=https://moodle.suainstituicao.edu/login/index.php

# Lista de URLs dos fóruns separadas por vírgula (sem espaços entre elas)
# Cada URL deve apontar para a página principal do fórum (não para o post.php)
MOODLE_FORUM_URLS=https://moodle.suainstituicao.edu/mod/forum/view.php?id=1111,https://moodle.suainstituicao.edu/mod/forum/view.php?id=2222

# Define se o processo deve rodar em modo headless (sem interface gráfica)
# Use true para produção, false para depuração visual
MOODLE_HEADLESS=true

# ==============================================================================
# CONFIGURAÇÕES DO CONTEÚDO
# ==============================================================================
# Caminho para o arquivo .md com o conteúdo do post (relativo a esta pasta)
# Se omitido, o módulo procura por post.md nesta mesma pasta
# MOODLE_POST_FILE=./post.md
