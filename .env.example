# ==============================================================================
# CONFIGURAÇÕES DO MOODLE (ESCOPO 1 - EXTRAÇÃO)
# ==============================================================================
MOODLE_USERNAME=seu_usuario_aqui
MOODLE_PASSWORD=sua_senha_aqui

# URL da página de login do Moodle
MOODLE_LOGIN_URL=https://moodle.suainstituicao.edu/login/index.php

# Lista de URLs dos relatórios separadas por vírgula (sem espaços entre elas)
MOODLE_REPORT_URLS=https://moodle.suainstituicao.edu/mod/feedback/show_entries.php?id=1111,https://moodle.suainstituicao.edu/mod/feedback/show_entries.php?id=2222

# Caminho relativo ou absoluto onde os relatórios brutos (relatorio1.csv, etc) serão salvos
MOODLE_DOWNLOAD_DIR=./dados/relatorios

# Define se o processo deve rodar em modo headless (sem interface gráfica)
MOODLE_HEADLESS=true


# ==============================================================================
# CONFIGURAÇÕES DA ANÁLISE PENTE-FINO (ESCOPO 2 - MIDDLEWARE)
# ==============================================================================
# Nome ou caminho da planilha principal de estudantes (deve estar na pasta de downloads ou caminho absoluto)
MOODLE_STUDENTS_CSV=./dados/residentes.csv

# Caminho completo e nome do arquivo gerado com o cruzamento final de dados
MOODLE_ANALYSIS_OUTPUT_CSV=./dados/resultado.csv


# ==============================================================================
# CONFIGURAÇÕES DO GOOGLE SHEETS (ESCOPO 3)
# ==============================================================================
# O ID fica na URL da planilha: https://docs.google.com/spreadsheets/d/ID_AQUI/edit
GOOGLE_SHEETS_ID=seu_id_longo_da_planilha_aqui

# Nome exato da aba (página) que você quer atualizar (ex: Engenharia, Geral, Página1)
GOOGLE_SHEETS_ABA_NAME=Página1

# Caminho para o JSON de credenciais que você baixou
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ==============================================================================
# CONFIGURAÇÕES DO PIPELINE GERAL
# ==============================================================================
# Define o ambiente de execução (development, production)
ENVIRONMENT=development

# Nível de logs do sistema (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


