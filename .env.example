# ==============================================================================
# CONFIGURAÇÕES DO MOODLE (ESCOPO 1)
# ==============================================================================
MOODLE_USERNAME=seu_usuario_aqui
MOODLE_PASSWORD=sua_senha_aqui

# URL da página de login do Moodle
MOODLE_LOGIN_URL=https://moodle.suainstituicao.edu/login/index.php

# Lista de URLs dos relatórios separadas por vírgula (sem espaços entre elas)
MOODLE_REPORT_URLS=https://moodle.suainstituicao.edu/mod/feedback/show_entries.php?id=1111,https://moodle.suainstituicao.edu/mod/feedback/show_entries.php?id=2222

# Caminho relativo ou absoluto onde os relatórios brutos (relatorio1.csv, etc) serão salvos
MOODLE_DOWNLOAD_DIR=./relatorios_moodle

# Define se o processo deve rodar em modo headless (sem interface gráfica)
MOODLE_HEADLESS=true


# ==============================================================================
# CONFIGURAÇÕES DO PIPELINE GERAL
# ==============================================================================
# Define o ambiente de execução (development, production)
ENVIRONMENT=development

# Nível de logs do sistema (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


